# Use this instead of .env.example ONLY if you are running PostgreSQL
# directly on your machine (via pgAdmin/local install) instead of via
# docker-compose. Rename to .env and fill in your own password.
APP_NAME=HMZC Marine Inspection System
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/hmzc_database
SECRET_KEY=change_this_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
