APP_NAME=HMZC Marine Inspection System
# Matches docker-compose.yml postgres service credentials below.
DATABASE_URL=postgresql://hmzc_user:password@postgres:5432/hmzc_db
# Generate a real value — `openssl rand -hex 32` — and put it in your
# actual .env, not this file. The app now refuses to start at all if
# this is still the placeholder below (see core/config.py) or under 32
# characters, rather than silently running with a guessable secret.
SECRET_KEY=change_this_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Comma-separated. Add your deployed frontend's real URL here once you
# have one (e.g. Railway, Vercel) — the code default only covers local
# Vite dev (localhost:5173).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# All optional — account creation and password reset still work without
# these (the temporary password is shown on-screen to the admin either
# way), they just won't also send an email. Leave unset to skip email
# entirely; fill in a real SMTP account's details to enable it. Tested
# against a real SMTP protocol exchange during development — see
# core/email.py's own comment — but never against a real provider,
# since this file intentionally doesn't ship with anyone's actual
# credentials.
#
# Gmail: smtp.gmail.com, port 587, an App Password (not your normal
#   Gmail password) — https://myaccount.google.com/apppasswords
# SendGrid/Postmark/AWS SES: each has its own SMTP relay — check their
#   docs for host/port/credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Used to build the sign-in link inside account-creation/password-reset
# emails. Set to your real deployed frontend URL once you have one.
FRONTEND_URL=http://localhost:5173
